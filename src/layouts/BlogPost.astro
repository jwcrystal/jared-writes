---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Tags from '../components/Tags.astro';

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ReturnType<CollectionEntry<'blog'>['data']['heroImage']>;
  tags?: string[];
  tocDepth?: number;
  prevPost?: { title: string; slug: string } | null;
  nextPost?: { title: string; slug: string } | null;
  headings?: { depth: number; slug: string; text: string }[];
}

const {
  title, description, pubDate, updatedDate, heroImage,
  tags, tocDepth = 2, prevPost, nextPost, headings,
} = Astro.props;

// Compute which headings to show in TOC
const showToc = tocDepth >= 2;
const tocHeadings = showToc && headings
  ? headings.filter(h => h.depth >= 2 && h.depth <= tocDepth)
  : [];
const hasToc = tocHeadings.length >= 2;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${title} — Jared Writes`} description={description} />
  </head>
  <body>
    <Header />
    <main class="post">
      <div class="post-layout">
        <article class="post-article">
          <header class="post-header">
            <a href={`${base}blog`} class="back-link">&larr; All posts</a>
            <div class="post-meta">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="updated">
                  &middot; Updated <FormattedDate date={updatedDate} />
                </span>
              )}
            </div>
            <h1 class="post-title">{title}</h1>
            {description && (
              <p class="post-subtitle">{description}</p>
            )}
            {tags && tags.length > 0 && (
              <div class="post-tags">
                <Tags tags={tags} size="md" />
              </div>
            )}
          </header>

          {heroImage && (
            <div class="hero-image">
              <Image width={680} height={340} src={heroImage} alt="" />
            </div>
          )}

          {hasToc && (
            <nav class="toc-mobile" aria-label="Table of contents">
              <details>
                <summary class="toc-label">On this page</summary>
                <ul class="toc-list">
                  {tocHeadings.map((h) => (
                    <li class={`toc-item toc-item--h${h.depth}`}>
                      <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
                    </li>
                  ))}
                </ul>
              </details>
            </nav>
          )}

          <div class="prose">
            <slot />
          </div>
        </article>

        {hasToc && (
          <aside class="post-sidebar">
            <nav class="toc-desktop">
              <p class="toc-label">On this page</p>
              <ul class="toc-list">
                {tocHeadings.map((h) => (
                  <li class="toc-item">
                    <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}
      </div>

      {(prevPost || nextPost) && (
        <nav class="post-nav" aria-label="Previous and next posts">
          {prevPost ? (
            <a href={`${base}blog/${prevPost.slug}/`} class="post-nav-link post-nav-prev">
              <span class="post-nav-direction">&larr; Previous</span>
              <span class="post-nav-title">{prevPost.title}</span>
            </a>
          ) : <span />}
          {nextPost ? (
            <a href={`${base}blog/${nextPost.slug}/`} class="post-nav-link post-nav-next">
              <span class="post-nav-direction">Next &rarr;</span>
              <span class="post-nav-title">{nextPost.title}</span>
            </a>
          ) : <span />}
        </nav>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  /* ── Layout ── */
  .post {
    padding-top: 2rem;
  }

  .post-layout {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    align-items: start;
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .post-article {
    max-width: var(--max-width);
    min-width: 0;
    flex: 0 1 var(--max-width);
  }

  .post-sidebar {
    width: 140px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
    padding-top: 0.5rem;
  }

  /* ── Article Header ── */
  .post-header {
    margin-bottom: 2.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.82rem;
    color: var(--text-tertiary);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .post-meta {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    margin-bottom: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  .updated {
    color: var(--text-tertiary);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: normal;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 0.5rem;
    color: var(--text);
  }

  .post-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Tags ── */
  .post-tags {
    margin: 1.25rem 0 0;
  }

  /* ── Hero ── */
  .hero-image {
    margin-bottom: 2.5rem;
  }

  .hero-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  /* ── Prose ── */
  .prose {
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .prose :global(h1) { font-size: 1.8em; }
  .prose :global(h2) { font-size: 1.45em; }
  .prose :global(h3) { font-size: 1.2em; }
  .prose :global(h4) { font-size: 1.05em; }

  .prose :global(p) {
    margin-bottom: 1.5em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.5em;
  }

  .prose :global(blockquote) {
    margin: 2em 0;
  }

  .prose :global(hr) {
    margin: 2.5em 0;
  }

  .prose :global(img) {
    margin: 1.5em 0;
  }

  /* ── Table of Contents — Mobile ── */
  .toc-mobile {
    display: none;
    margin-bottom: 1.5rem;
    padding: 0.75rem 1rem;
    background: var(--accent-subtle);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.85rem;
  }

  .toc-mobile .toc-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    cursor: pointer;
    user-select: none;
  }

  .toc-mobile .toc-list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }

  /* ── Table of Contents — Desktop Sidebar ── */
  .toc-desktop {
    font-size: 0.78rem;
  }

  .toc-desktop .toc-label {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin: 0 0 0.5rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    padding: 0.1em 0;
    line-height: 1.3;
  }

  .toc-item--h3 {
    padding-left: 0.75em;
  }

  .toc-link {
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .toc-link:hover {
    color: var(--accent);
  }

  /* ── Previous / Next Navigation ── */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: var(--max-width);
    margin: 3.5rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    padding: 0.75rem;
    border-radius: 6px;
    transition: background 0.15s ease;
  }

  .post-nav-link:hover {
    background: var(--accent-subtle);
  }

  .post-nav-next {
    text-align: right;
  }

  .post-nav-direction {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
  }

  .post-nav-title {
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.4;
    transition: color 0.15s ease;
  }

  .post-nav-link:hover .post-nav-title {
    color: var(--accent);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .post-layout {
      flex-direction: column;
      gap: 0;
    }

    .post-sidebar {
      display: none;
    }

    .toc-mobile {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .post {
      padding-top: 1.5rem;
    }

    .post-title {
      font-size: 1.7rem;
    }

    .prose {
      font-size: 1rem;
    }

    .post-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
