---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Tags from '../components/Tags.astro';

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ReturnType<CollectionEntry<'blog'>['data']['heroImage']>;
  tags?: string[];
  prevPost?: { title: string; slug: string } | null;
  nextPost?: { title: string; slug: string } | null;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, updatedDate, heroImage, tags, prevPost, nextPost, headings } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${title} — Jared Writes`} description={description} />
  </head>
  <body>
    <Header />
    <main class="post">
      <article>
        <header class="post-header">
          <a href={`${base}blog`} class="back-link">&larr; All posts</a>
          <div class="post-meta">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="updated">
                &middot; Updated <FormattedDate date={updatedDate} />
              </span>
            )}
          </div>
          <h1 class="post-title">{title}</h1>
          {description && (
            <p class="post-subtitle">{description}</p>
          )}
          {tags && tags.length > 0 && (
            <div class="post-tags">
              <Tags tags={tags} size="md" />
            </div>
          )}
        </header>

        {heroImage && (
          <div class="hero-image">
            <Image width={680} height={340} src={heroImage} alt="" />
          </div>
        )}

        {headings && headings.length > 1 && (
          <nav class="toc" aria-label="Table of contents">
            <details open>
              <summary class="toc-label">On this page</summary>
              <ul class="toc-list">
                {headings.filter(h => h.depth <= 3).map((h) => (
                  <li class={`toc-item toc-item--h${h.depth}`}>
                    <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
                  </li>
                ))}
              </ul>
            </details>
          </nav>
        )}

        <div class="prose">
          <slot />
        </div>
      </article>

      {(prevPost || nextPost) && (
        <nav class="post-nav" aria-label="Previous and next posts">
          {prevPost ? (
            <a href={`${base}blog/${prevPost.slug}/`} class="post-nav-link post-nav-prev">
              <span class="post-nav-direction">&larr; Previous</span>
              <span class="post-nav-title">{prevPost.title}</span>
            </a>
          ) : <span />}
          {nextPost ? (
            <a href={`${base}blog/${nextPost.slug}/`} class="post-nav-link post-nav-next">
              <span class="post-nav-direction">Next &rarr;</span>
              <span class="post-nav-title">{nextPost.title}</span>
            </a>
          ) : <span />}
        </nav>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  .post {
    padding-top: 2rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.82rem;
    color: var(--text-tertiary);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .post-meta {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    margin-bottom: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  .updated {
    color: var(--text-tertiary);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: normal;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 0.5rem;
    color: var(--text);
  }

  .post-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .hero-image {
    margin-bottom: 2.5rem;
  }

  .hero-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .prose {
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .prose :global(h1) { font-size: 1.8em; }
  .prose :global(h2) { font-size: 1.45em; }
  .prose :global(h3) { font-size: 1.2em; }
  .prose :global(h4) { font-size: 1.05em; }

  .prose :global(p) {
    margin-bottom: 1.5em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.5em;
  }

  .prose :global(blockquote) {
    margin: 2em 0;
  }

  .prose :global(hr) {
    margin: 2.5em 0;
  }

  .prose :global(img) {
    margin: 1.5em 0;
  }

  /* ── Tags ── */
  .post-tags {
    margin: 1.25rem 0 0;
  }

  /* ── Table of Contents ── */
  .toc {
    margin-bottom: 2.5rem;
    padding: 1rem 1.25rem;
    background: var(--accent-subtle);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.88rem;
  }

  .toc-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    cursor: pointer;
    user-select: none;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }

  .toc-item {
    padding: 0.15em 0;
  }

  .toc-item--h3 {
    padding-left: 1.25em;
  }

  .toc-link {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .toc-link:hover {
    color: var(--accent);
  }

  /* ── Previous / Next Navigation ── */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    padding: 0.75rem;
    border-radius: 6px;
    transition: background 0.15s ease;
  }

  .post-nav-link:hover {
    background: var(--accent-subtle);
  }

  .post-nav-next {
    text-align: right;
  }

  .post-nav-direction {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
  }

  .post-nav-title {
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.4;
    transition: color 0.15s ease;
  }

  .post-nav-link:hover .post-nav-title {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .post {
      padding-top: 1.5rem;
    }

    .post-title {
      font-size: 1.7rem;
    }

    .prose {
      font-size: 1rem;
    }

    .post-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
