---
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <div class="footer-rule"></div>
    <p class="footer-text">
      &copy; {today.getFullYear()} Jared Writes
    </p>
  </div>
</footer>

<style>
  footer {
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
  }

  .footer-rule {
    width: 40px;
    height: 2px;
    background: var(--border);
    margin-bottom: 1.25rem;
  }

  .footer-text {
    font-size: 0.82rem;
    color: var(--text-tertiary);
    margin: 0;
  }
</style>
