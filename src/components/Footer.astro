---
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <div class="footer-rule"></div>
    <p class="footer-text">
      &copy; {today.getFullYear()} Jared Writes
    </p>
  </div>
</footer>

<style>
  footer {
    margin-top: 4rem;
  }

  .footer-inner {
    width: min(1120px, calc(100% - 3rem));
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 0 2rem;
  }

  @media (max-width: 640px) {
    .footer-inner {
      width: calc(100% - 2.5rem);
    }
  }

  .footer-rule {
    width: 40px;
    height: 2px;
    background: var(--border);
    margin-bottom: 1.25rem;
  }

  .footer-text {
    font-size: 0.82rem;
    color: var(--text-tertiary);
    margin: 0;
  }
</style>
