---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const visibleTagCount = 3;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <header class="page-header">
        <h1>Blog</h1>
        <p class="page-description">
          Thoughts on code, books, and things worth thinking about.
        </p>
      </header>

      {posts.length === 0 ? (
        <p class="empty">No posts yet. Check back soon.</p>
      ) : (
        <ul class="post-list" aria-label="Blog posts">
          {posts.map((post) => (
            <li class="post-item">
              <a href={`${base}blog/${post.id}/`} class="post-link">
                <div class="post-meta">
                  <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                    <FormattedDate date={post.data.pubDate} />
                  </time>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <span class="post-meta-tags" aria-label={`Tags: ${post.data.tags.join(', ')}`}>
                      {post.data.tags.slice(0, visibleTagCount).map((tag, index) => (
                        <span class="post-meta-tag">
                          {index > 0 && <span class="post-meta-separator" aria-hidden="true">·</span>}
                          {tag}
                        </span>
                      ))}
                      {post.data.tags.length > visibleTagCount && (
                        <span class="post-meta-more">
                          <span class="post-meta-separator" aria-hidden="true">·</span>
                          +{post.data.tags.length - visibleTagCount}
                        </span>
                      )}
                    </span>
                  )}
                </div>
                <div class="post-content">
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.description && (
                    <p class="post-description">{post.data.description}</p>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: normal;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }

  .page-description {
    font-size: 1.05rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .empty {
    color: var(--text-tertiary);
    font-style: italic;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    border-top: 1px solid var(--border-light);
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--border-light);
  }

  .post-link {
    display: block;
    padding: 1rem 0.75rem;
    margin: 0 -0.75rem;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.2s ease;
  }

  .post-link:hover {
    background: var(--accent-subtle);
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.2rem;
  }

  .post-date {
    font-size: 0.82rem;
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    line-height: 1.5;
  }

  .post-meta-tags {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    min-width: 0;
  }

  .post-meta-tags::before {
    content: '·';
    color: var(--text-tertiary);
  }

  .post-meta-tag,
  .post-meta-more {
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--text-tertiary);
  }

  .post-meta-separator {
    padding: 0 0.35rem;
    color: var(--text-tertiary);
  }

  .post-link:hover .post-meta-tag,
  .post-link:hover .post-meta-more {
    color: var(--accent);
  }

  .post-content {
    min-width: 0;
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: normal;
    color: var(--text);
    margin: 0 0 0.3rem;
    line-height: 1.35;
    transition: color 0.15s ease;
  }

  .post-description {
    font-size: 0.92rem;
    color: var(--text-secondary);
    margin: 0 0 0.5rem;
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .page-header h1 {
      font-size: 1.8rem;
    }

    .post-link {
      padding: 0.9rem 0.75rem;
      margin: 0 -0.75rem;
    }

    .post-title {
      font-size: 1.1rem;
    }
  }
</style>
