---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;

// Get all posts sorted by date to find prev/next
const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sorted.findIndex((p) => p.id === post.id);

const prevPost = currentIndex < sorted.length - 1
	? { title: sorted[currentIndex + 1].data.title, slug: sorted[currentIndex + 1].id }
	: null;

const nextPost = currentIndex > 0
	? { title: sorted[currentIndex - 1].data.title, slug: sorted[currentIndex - 1].id }
	: null;

const tocDepth = post.data.tocDepth ?? 2;
const { Content, headings } = await render(post);
---

<BlogPost
	{...post.data}
	tags={post.data.tags}
	tocDepth={tocDepth}
	prevPost={prevPost}
	nextPost={nextPost}
	headings={headings}
>
	<Content />
</BlogPost>
